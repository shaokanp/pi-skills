{
  "schema_version": "agent-workflow.model-routing-policy.v1",
  "snapshot_id": "quality-floor-codex-v1-policy-v1",
  "policy_id": "quality-floor-codex-v1",
  "policy_version": 1,
  "adapter_scope": "codex_builtin_subagents",
  "content_sha256": "sha256:e9b656c133804b279165a62be5fed74dc800a76cefc08ddd1bf93ca29e0aa959",
  "packet_taxonomy": {
    "schema_version": "agent-workflow.routing-packet.v1",
    "fields": {
      "ambiguity": {
        "enum": ["bounded", "material"]
      },
      "coupling": {
        "enum": ["local", "cross_boundary"]
      },
      "blast_radius": {
        "enum": ["local", "shared", "external_production"]
      },
      "reversibility": {
        "enum": ["easy", "bounded_rollback", "hard"]
      },
      "verifiability": {
        "enum": ["deterministic", "partial", "judgment_only"]
      },
      "novelty": {
        "enum": ["established", "novel"]
      },
      "role": {
        "enum": [
          "discover",
          "plan",
          "roundtable",
          "implement",
          "seam",
          "review",
          "challenge",
          "verify",
          "repair",
          "custom"
        ]
      },
      "claim_class": {
        "enum": ["routine", "judgment", "high_consequence"]
      },
      "approval_required": {
        "type": "boolean"
      }
    }
  },
  "automatic_floor": {
    "model": "gpt-5.6-terra",
    "effort": "high"
  },
  "route_order": [
    {
      "model": "gpt-5.6-terra",
      "effort": "high"
    },
    {
      "model": "gpt-5.6-terra",
      "effort": "xhigh"
    },
    {
      "model": "gpt-5.6-sol",
      "effort": "high"
    },
    {
      "model": "gpt-5.6-sol",
      "effort": "xhigh"
    },
    {
      "model": "gpt-5.6-sol",
      "effort": "max"
    }
  ],
  "automatic_exclusions": {
    "models": ["gpt-5.6-luna"],
    "efforts": ["low", "medium", "ultra"],
    "unclassified_models": true
  },
  "decision_rules": [
    {
      "id": "gate.approval_required",
      "priority": 10,
      "match": {
        "approval_required": [true]
      },
      "effect": {
        "gate": "human_gate"
      }
    },
    {
      "id": "route.sol_xhigh.final_high_consequence_verifier",
      "priority": 20,
      "match": {
        "role": ["verify"],
        "claim_class": ["high_consequence"]
      },
      "effect": {
        "model": "gpt-5.6-sol",
        "effort": "xhigh"
      }
    },
    {
      "id": "route.sol_xhigh.high_consequence_judgment",
      "priority": 30,
      "match": {
        "claim_class": ["high_consequence"],
        "verifiability": ["judgment_only"]
      },
      "effect": {
        "model": "gpt-5.6-sol",
        "effort": "xhigh"
      }
    },
    {
      "id": "route.sol_xhigh.novel_cross_boundary",
      "priority": 40,
      "match": {
        "ambiguity": ["material"],
        "coupling": ["cross_boundary"],
        "novelty": ["novel"]
      },
      "effect": {
        "model": "gpt-5.6-sol",
        "effort": "xhigh"
      }
    },
    {
      "id": "route.sol_high.high_consequence",
      "priority": 50,
      "match": {
        "claim_class": ["high_consequence"]
      },
      "effect": {
        "model": "gpt-5.6-sol",
        "effort": "high"
      }
    },
    {
      "id": "route.sol_high.external_production",
      "priority": 60,
      "match": {
        "blast_radius": ["external_production"]
      },
      "effect": {
        "model": "gpt-5.6-sol",
        "effort": "high"
      }
    },
    {
      "id": "route.sol_high.hard_reversal",
      "priority": 70,
      "match": {
        "reversibility": ["hard"]
      },
      "effect": {
        "model": "gpt-5.6-sol",
        "effort": "high"
      }
    },
    {
      "id": "route.sol_high.judgment_only",
      "priority": 80,
      "match": {
        "verifiability": ["judgment_only"]
      },
      "effect": {
        "model": "gpt-5.6-sol",
        "effort": "high"
      }
    },
    {
      "id": "route.terra_xhigh.material_ambiguity",
      "priority": 90,
      "match": {
        "ambiguity": ["material"]
      },
      "effect": {
        "model": "gpt-5.6-terra",
        "effort": "xhigh"
      }
    },
    {
      "id": "route.terra_xhigh.cross_boundary",
      "priority": 100,
      "match": {
        "coupling": ["cross_boundary"]
      },
      "effect": {
        "model": "gpt-5.6-terra",
        "effort": "xhigh"
      }
    },
    {
      "id": "route.terra_xhigh.partial_verification",
      "priority": 110,
      "match": {
        "verifiability": ["partial"]
      },
      "effect": {
        "model": "gpt-5.6-terra",
        "effort": "xhigh"
      }
    },
    {
      "id": "route.terra_xhigh.critical_role",
      "priority": 120,
      "match": {
        "role": ["plan", "roundtable", "review", "challenge", "verify"]
      },
      "effect": {
        "model": "gpt-5.6-terra",
        "effort": "xhigh"
      }
    },
    {
      "id": "route.terra_high.default",
      "priority": 1000,
      "match": {},
      "effect": {
        "model": "gpt-5.6-terra",
        "effort": "high"
      }
    }
  ],
  "verifier_rules": [
    {
      "id": "verify.sol_xhigh.high_consequence",
      "priority": 10,
      "match": {
        "claim_class": ["high_consequence"]
      },
      "effect": {
        "minimum_route": {
          "model": "gpt-5.6-sol",
          "effort": "xhigh"
        },
        "required": true,
        "missing_evidence_action": "human_gate"
      }
    },
    {
      "id": "verify.sol_xhigh.external",
      "priority": 20,
      "match": {
        "blast_radius": ["external_production"]
      },
      "effect": {
        "minimum_route": {
          "model": "gpt-5.6-sol",
          "effort": "xhigh"
        },
        "required": true,
        "missing_evidence_action": "human_gate"
      }
    },
    {
      "id": "verify.sol_xhigh.hard_reversal",
      "priority": 30,
      "match": {
        "reversibility": ["hard"]
      },
      "effect": {
        "minimum_route": {
          "model": "gpt-5.6-sol",
          "effort": "xhigh"
        },
        "required": true,
        "missing_evidence_action": "human_gate"
      }
    },
    {
      "id": "verify.sol_xhigh.judgment_only",
      "priority": 40,
      "match": {
        "claim_class": ["judgment"],
        "verifiability": ["judgment_only"]
      },
      "effect": {
        "minimum_route": {
          "model": "gpt-5.6-sol",
          "effort": "xhigh"
        },
        "required": true,
        "missing_evidence_action": "more_discovery"
      }
    },
    {
      "id": "verify.terra_xhigh.judgment",
      "priority": 50,
      "match": {
        "claim_class": ["judgment"]
      },
      "effect": {
        "minimum_route": {
          "model": "gpt-5.6-terra",
          "effort": "xhigh"
        },
        "required": true,
        "missing_evidence_action": "more_discovery"
      }
    },
    {
      "id": "verify.terra_xhigh.weak_evidence",
      "priority": 60,
      "match": {
        "verifiability": ["partial", "judgment_only"]
      },
      "effect": {
        "minimum_route": {
          "model": "gpt-5.6-terra",
          "effort": "xhigh"
        },
        "required": true,
        "missing_evidence_action": "more_discovery"
      }
    },
    {
      "id": "verify.terra_high.routine",
      "priority": 1000,
      "match": {},
      "effect": {
        "minimum_route": {
          "model": "gpt-5.6-terra",
          "effort": "high"
        },
        "required": false,
        "missing_evidence_action": "blocked"
      }
    }
  ],
  "override_policy": {
    "lead_may_raise": true,
    "user_may_raise": true,
    "lower_request_action": "human_gate"
  },
  "fallback_policy": {
    "high_guard_fields": [
      "claim_class=high_consequence",
      "blast_radius=external_production",
      "reversibility=hard",
      "verifiability=judgment_only",
      "approval_required=true"
    ],
    "low_risk_direction": "upward_only",
    "high_risk_action": "human_gate",
    "silent_fallback": false
  },
  "attempt_policy": {
    "same_route_retries": 1,
    "route_changes": 1,
    "sol_max_transition": "sol_xhigh_insufficient_reasoning_only",
    "exhausted_action": "repair_round_or_human_gate"
  }
}
