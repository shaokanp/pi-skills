{
  "schema_version": "agent-workflow.model-routing-policy.v2",
  "snapshot_id": "responsibility-routing-codex-v2-policy-v1",
  "policy_id": "responsibility-routing-codex-v2",
  "policy_version": 1,
  "adapter_scope": "codex_builtin_subagents",
  "content_sha256": "sha256:9ee591b005e866836dbddd144bfdf5f85300879a375ce8af59d676cf0c7a6d44",
  "packet_taxonomy": {
    "schema_version": "agent-workflow.routing-packet.v1",
    "fields": {
      "ambiguity": {"enum": ["bounded", "material"]},
      "coupling": {"enum": ["local", "cross_boundary"]},
      "blast_radius": {"enum": ["local", "shared", "external_production"]},
      "reversibility": {"enum": ["easy", "bounded_rollback", "hard"]},
      "verifiability": {"enum": ["deterministic", "partial", "judgment_only"]},
      "novelty": {"enum": ["established", "novel"]},
      "role": {
        "enum": [
          "discover",
          "plan",
          "roundtable",
          "implement",
          "seam",
          "review",
          "challenge",
          "verify",
          "repair",
          "custom"
        ]
      },
      "claim_class": {"enum": ["routine", "judgment", "high_consequence"]},
      "approval_required": {"type": "boolean"}
    }
  },
  "default_model": "gpt-5.6-terra",
  "model_order": ["gpt-5.6-terra", "gpt-5.6-sol"],
  "automatic_exclusions": {
    "models": ["gpt-5.6-luna"],
    "unclassified_models": true
  },
  "decision_rules": [
    {
      "id": "gate.approval_required",
      "priority": 10,
      "match": {"approval_required": [true]},
      "effect": {"gate": "human_gate"}
    },
    {
      "id": "route.sol.thinking_role",
      "priority": 20,
      "match": {"role": ["plan", "roundtable", "review", "challenge", "verify"]},
      "effect": {"model": "gpt-5.6-sol"}
    },
    {
      "id": "route.sol.material_ambiguity",
      "priority": 30,
      "match": {"ambiguity": ["material"]},
      "effect": {"model": "gpt-5.6-sol"}
    },
    {
      "id": "route.sol.cross_boundary",
      "priority": 40,
      "match": {"coupling": ["cross_boundary"]},
      "effect": {"model": "gpt-5.6-sol"}
    },
    {
      "id": "route.sol.external_production",
      "priority": 50,
      "match": {"blast_radius": ["external_production"]},
      "effect": {"model": "gpt-5.6-sol"}
    },
    {
      "id": "route.sol.hard_reversal",
      "priority": 60,
      "match": {"reversibility": ["hard"]},
      "effect": {"model": "gpt-5.6-sol"}
    },
    {
      "id": "route.sol.weak_verifiability",
      "priority": 70,
      "match": {"verifiability": ["partial", "judgment_only"]},
      "effect": {"model": "gpt-5.6-sol"}
    },
    {
      "id": "route.sol.novel",
      "priority": 80,
      "match": {"novelty": ["novel"]},
      "effect": {"model": "gpt-5.6-sol"}
    },
    {
      "id": "route.sol.judgment_claim",
      "priority": 90,
      "match": {"claim_class": ["judgment", "high_consequence"]},
      "effect": {"model": "gpt-5.6-sol"}
    },
    {
      "id": "route.terra.bounded_execution",
      "priority": 1000,
      "match": {},
      "effect": {"model": "gpt-5.6-terra"}
    }
  ],
  "verifier_rules": [
    {
      "id": "verify.sol.high_consequence",
      "priority": 10,
      "match": {"claim_class": ["high_consequence"]},
      "effect": {
        "minimum_model": "gpt-5.6-sol",
        "required": true,
        "missing_evidence_action": "human_gate"
      }
    },
    {
      "id": "verify.sol.external",
      "priority": 20,
      "match": {"blast_radius": ["external_production"]},
      "effect": {
        "minimum_model": "gpt-5.6-sol",
        "required": true,
        "missing_evidence_action": "human_gate"
      }
    },
    {
      "id": "verify.sol.hard_reversal",
      "priority": 30,
      "match": {"reversibility": ["hard"]},
      "effect": {
        "minimum_model": "gpt-5.6-sol",
        "required": true,
        "missing_evidence_action": "human_gate"
      }
    },
    {
      "id": "verify.sol.judgment",
      "priority": 40,
      "match": {"claim_class": ["judgment"]},
      "effect": {
        "minimum_model": "gpt-5.6-sol",
        "required": true,
        "missing_evidence_action": "more_discovery"
      }
    },
    {
      "id": "verify.sol.weak_evidence",
      "priority": 50,
      "match": {"verifiability": ["partial", "judgment_only"]},
      "effect": {
        "minimum_model": "gpt-5.6-sol",
        "required": true,
        "missing_evidence_action": "more_discovery"
      }
    },
    {
      "id": "verify.terra.routine",
      "priority": 1000,
      "match": {},
      "effect": {
        "minimum_model": "gpt-5.6-terra",
        "required": false,
        "missing_evidence_action": "blocked"
      }
    }
  ],
  "override_policy": {
    "lead_may_raise_model": true,
    "user_may_raise_model": true,
    "effort_override_allowed": false,
    "lower_model_request_action": "human_gate"
  },
  "fallback_policy": {
    "terra_unavailable": "upgrade_to_sol_same_effort",
    "sol_unavailable": "human_gate",
    "silent_fallback": false
  },
  "attempt_policy": {
    "same_model_retries": 1,
    "model_changes": 1,
    "allowed_model_change": "terra_to_sol_same_effort",
    "exhausted_action": "repair_round_or_human_gate"
  }
}
