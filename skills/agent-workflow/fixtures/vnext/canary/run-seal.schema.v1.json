{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Workflow vNext pre-result canary run seal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "fixture_seal_sha256",
    "executable_freeze_sha256",
    "candidate_bundle_sha256",
    "runtime_bundle_sha256",
    "repository_fixture_ref",
    "repository_fixture_sha256",
    "codex_identity_ref",
    "codex_identity_sha256",
    "codex_version",
    "app_protocol_schema_sha256",
    "host_profile_ref",
    "host_profile_sha256",
    "top_model",
    "worker_model",
    "reasoning_effort",
    "capacity_profile_ref",
    "capacity_profile_sha256",
    "paired_order_seed",
    "blind_label_map_ref",
    "blind_label_map_sha256",
    "rubric_ref",
    "rubric_sha256",
    "sealed_at",
    "host_authority_id",
    "results_ref",
    "freeze_path",
    "repository_root"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "agent-workflow.canary-run-seal.v1"},
    "fixture_seal_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "executable_freeze_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "candidate_bundle_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "runtime_bundle_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "repository_fixture_ref": {"type": "string", "minLength": 1},
    "repository_fixture_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "codex_identity_ref": {"type": "string", "minLength": 1},
    "codex_identity_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "codex_version": {"type": "string", "minLength": 1},
    "app_protocol_schema_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "host_profile_ref": {"type": "string", "minLength": 1},
    "host_profile_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "top_model": {"type": "string", "minLength": 1},
    "worker_model": {"type": "string", "minLength": 1},
    "reasoning_effort": {"type": "string", "minLength": 1},
    "capacity_profile_ref": {"type": "string", "minLength": 1},
    "capacity_profile_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "paired_order_seed": {"type": "string", "minLength": 1},
    "blind_label_map_ref": {"type": "string", "minLength": 1},
    "blind_label_map_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "rubric_ref": {"type": "string", "minLength": 1},
    "rubric_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "sealed_at": {"type": "string", "format": "date-time"},
    "host_authority_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "results_ref": {"type": "string", "minLength": 1},
    "freeze_path": {"type": "string", "minLength": 1},
    "repository_root": {"type": "string", "minLength": 1}
  }
}
